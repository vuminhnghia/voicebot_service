# Copy this file to .env.local for local development.
# Start infrastructure first: just infra-up
# Worker requires Triton for inference: docker compose up -d triton

TRITON_URL=localhost:8000

REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql+asyncpg://voicebot:voicebot@localhost:5432/voicebot
RABBITMQ_URL=amqp://voicebot:voicebot@localhost:5672/

SEAWEEDFS_ENDPOINT=http://localhost:8333
SEAWEEDFS_BUCKET=voicebot
SEAWEEDFS_ACCESS_KEY=voicebot-access-key
SEAWEEDFS_SECRET_KEY=voicebot-secret-key-change-in-prod

SYSTEM_PROMPT=Bạn là trợ lý AI giọng nói hữu ích. Trả lời ngắn gọn, tự nhiên bằng tiếng Việt.
MAX_TOKENS=500
