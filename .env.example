# Copy this file to .env and change all values before deploying to production

# PostgreSQL
POSTGRES_PASSWORD=change_me_in_prod

# RabbitMQ
RABBITMQ_PASSWORD=change_me_in_prod

# Grafana
GRAFANA_ADMIN_PASSWORD=change_me_in_prod

# SeaweedFS S3 credentials (must match infra/seaweedfs/s3.json)
SEAWEEDFS_ACCESS_KEY=change_me_in_prod
SEAWEEDFS_SECRET_KEY=change_me_in_prod
